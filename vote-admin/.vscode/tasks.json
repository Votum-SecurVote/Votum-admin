{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Spring Boot Backend",
      "type": "shell",
      "command": "mvn spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}/backend-spring",
        "env": {
          "PGHOST": "localhost",
          "PGPORT": "5432",
          "PGDATABASE": "vote_admin",
          "PGUSER": "postgres",
          "PGPASSWORD": "mypassword123",
          "JWT_SECRET": "dev_jwt_secret_123",
          "PORT": "5000"
        }
      },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend-spring"
      },
      "runOptions": {
        "runOn": "default"
      }
    },
    {
      "label": "Start Node.js Backend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend-node"
      },
      "runOptions": {
        "runOn": "default"
      }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontend"
      },
      "runOptions": {
        "runOn": "default"
      }
    },
    {
      "label": "Start All Services",
      "dependsOn": [
        "Start Spring Boot Backend",
        "Start Frontend"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
