{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Launch Spring Boot Backend",
      "request": "launch",
      "mainClass": "com.voteadmin.VoteAdminApplication",
      "projectName": "vote-admin-backend",
      "cwd": "${workspaceFolder}/backend-spring",
      "env": {
        "PGHOST": "localhost",
        "PGPORT": "5432",
        "PGDATABASE": "vote_admin",
        "PGUSER": "postgres",
        "PGPASSWORD": "mypassword123",
        "JWT_SECRET": "dev_jwt_secret_123",
        "PORT": "5000"
      },
      "vmArgs": "-Dspring.profiles.active=local"
    },
    {
      "type": "node",
      "name": "Launch Node.js Backend",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "name": "Launch Frontend",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Launch All Services",
      "configurations": [
        "Launch Spring Boot Backend",
        "Launch Frontend"
      ],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "",
        "order": 1
      }
    }
  ]
}
